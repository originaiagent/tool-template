{
  "permissions": {
    "allow": [
      "git checkout",
      "git branch",
      "git add",
      "git commit",
      "git push origin claude/",
      "git pull",
      "git fetch",
      "git merge",
      "git log",
      "git diff",
      "git status",
      "git stash",
      "npm install",
      "npm run build",
      "npm run dev",
      "npm run lint",
      "npm run test",
      "npm run start",
      "npx",
      "pip install",
      "pip freeze",
      "python",
      "python3",
      "streamlit run",
      "curl http://localhost",
      "curl https://",
      "cat",
      "ls",
      "mkdir",
      "cp",
      "mv",
      "rm",
      "touch",
      "head",
      "tail",
      "grep",
      "find",
      "wc",
      "echo",
      "which",
      "node",
      "npx supabase",
      "npx tsc --noEmit",
      "lsof -i",
      "kill",
      "sleep"
    ],
    "deny": [
      "git push origin main",
      "git push --force",
      "git push -f",
      "git reset --hard",
      "git checkout main && git merge",
      "rm -rf /",
      "rm -rf .",
      "sudo"
    ]
  }
}
